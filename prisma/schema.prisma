datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model AttackReport {
  id             Int      @id @default(autoincrement())
  defenderCoords String
  attackerCoords String
  landingTime    DateTime
  firstSeenTime  DateTime
  tribe          String
  reporter       String?
  createdAt      DateTime @default(now())
}
